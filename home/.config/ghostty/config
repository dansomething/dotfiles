cursor-style-blink = true
font-family = Hack Nerd Font
font-size = 12
fullscreen = true
initial-command = /usr/bin/env bash -l -c "command -v tmux >/dev/null && tmux new-session -A -s main || { echo 'tmux is not installed. Install it with: brew install tmux'; exec bash; }"
macos-option-as-alt = true
quit-after-last-window-closed = true
theme = Jellybeans-custom
window-padding-x = 0
window-padding-y = 0
